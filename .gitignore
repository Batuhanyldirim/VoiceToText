# ─── Secrets (NEVER commit) ───────────────────────────────────────────────
.hf_token
*.token
.env

# ─── Downloaded models & caches (multi-GB, reproducible via requirements.txt) ─
models/
.pip-cache/
.venv/

# ─── Generated output ─────────────────────────────────────────────────────
out/

# ─── Media: audio & video (large; often private recordings) ───────────────
# Keep the repo code-only. Regenerate the test clip with `bash make_sample.sh`.
*.wav
*.mp3
*.m4a
*.flac
*.ogg
*.aac
*.mp4
*.mov
*.mkv
*.webm
*.avi
*.aiff
samples/

# ─── Python junk ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.DS_Store

# ─── Node / frontend (apps/web) ───────────────────────────────────────────
node_modules/
apps/web/dist/
apps/web/.vite/

# ─── API runtime job scratch (uploaded files + per-job temp) ──────────────
apps/api/jobs/
jobs/

# ─── Persistent notes DB (contains PHI — NEVER commit; ADR-0003/0009) ──────
apps/api/notes.db
*.db
*.db-journal
*.db-wal

# ─── Note source audio (PHI — NEVER commit; ADR-0019/0003) ─────────────────
apps/api/note_audio/
note_audio/

# ─── Eval harness: PHI reference data + transcription cache (NEVER commit) ─
# The committed smoke manifest (eval/manifests/smoke-en.json) + code are fine;
# the real Turkish CLINICAL reference set (hand-corrected real encounters) is
# PHI and lives here, git-ignored, alongside a git-ignored clinical manifest.
# The transcription cache holds transcript text derived from that audio.
eval/data/
eval/cache/
eval/manifests/clinical-tr.json
# Public benchmark ingested locally (FLEURS tr WAVs are large; regenerate via
# stt_eval.ingest_fleurs). CC-BY data + its generated manifest stay out of git.
eval/manifests/fleurs-tr.json

# ─── Machine-local, non-committed integrations ────────────────────────────
# Optional local note-provider plugin + its enablement. Kept out of git so the
# committed repo offers only the local (Ollama) provider and carries no
# machine-specific integration code.
env.local.sh
README.local.md
packages/note-core/src/note_core/_local_providers.py
