# ─── Secrets (NEVER commit) ───────────────────────────────────────────────
.hf_token
*.token
.env

# ─── Downloaded models & caches (multi-GB, reproducible via requirements.txt) ─
models/
.pip-cache/
.venv/

# ─── Generated output ─────────────────────────────────────────────────────
out/

# ─── Media: audio & video (large; often private recordings) ───────────────
# Keep the repo code-only. Regenerate the test clip with `bash make_sample.sh`.
*.wav
*.mp3
*.m4a
*.flac
*.ogg
*.aac
*.mp4
*.mov
*.mkv
*.webm
*.avi
*.aiff
samples/

# ─── Python junk ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.DS_Store

# ─── Node / frontend (apps/web) ───────────────────────────────────────────
node_modules/
apps/web/dist/
apps/web/.vite/

# ─── API runtime job scratch (uploaded files + per-job temp) ──────────────
apps/api/jobs/
jobs/

# ─── Persistent notes DB (contains PHI — NEVER commit; ADR-0003/0009) ──────
apps/api/notes.db
*.db
*.db-journal
*.db-wal
